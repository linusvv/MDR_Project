<launch>
    <arg name="use_rviz" default="false"/>
    <!-- 1. Start Gazebo simulation with mecanum robot -->
    <include file="$(find nexus_4wd_mecanum_gazebo)/launch/nexus_4wd_mecanum_world.launch" />

    <!-- 2. Start local costmap generator (converts Realsense pointcloud to 2D occupancy grid for motion primitives planner) -->
    <include file="$(find local_costmap_generator)/launch/run.launch" />

    <!-- 3. Start RTAB-Map SLAM (Configured to use stable Wheel Odometry) -->
    <include file="$(find rtabmap_launch)/launch/rtabmap.launch">
        <arg name="rtabmap_args" value="--delete_db_on_start --Vis/MaxFeatures 1000 --Kp/MaxFeatures 1000 --Rtabmap/LoopThr 0.3 --Rtabmap/DetectionRate 2"/>
        <arg name="rgb_topic" value="/camera/color/image_raw"/>
        <arg name="depth_topic" value="/camera/depth/image_raw"/>
        <arg name="camera_info_topic" value="/camera/color/camera_info"/>
        <arg name="depth_camera_info_topic" value="/camera/depth/camera_info"/>
        <arg name="frame_id" value="base_footprint"/>
        <arg name="odom_topic" value="/odom"/>
        <arg name="visual_odometry" value="false"/>
        <arg name="icp_odometry" value="false"/>
        <arg name="publish_tf_odom" value="false"/>
        <arg name="vo_frame_id" value="odom"/>
        <arg name="subscribe_scan" value="false"/>
        <arg name="approx_sync" value="true"/>
        <arg name="rviz" value="false"/>
        <arg name="rtabmap_viz" value="false"/>
    </include>

    <!-- 3.5 Start AprilTag Localization for global pose correction -->
    <include file="$(find apriltag_localization)/launch/apriltag_localization.launch">
        <arg name="tag_file_name" value="2025/re540_n1_room111" />
        <arg name="camera_name" value="/camera/color" />
        <arg name="image_topic" value="image_raw" />
        <arg name="world_frame_name" value="map" />
        <arg name="camera_frame_name" value="camera_link" />
        <arg name="image_frame_name" value="camera_color_optical_frame" />
        <arg name="with_visualization" value="false" />
        <arg name="with_realsense_tf" value="false" />
        <arg name="broadcast_world2cam_tf" value="false" />
    </include>

    <!-- 3.6 Start the Tag Pose Injector to continuously correct RTAB-Map global pose -->
    <node name="tag_pose_injector" pkg="hw4_exploration" type="tag_pose_injector.py" output="screen" />

    <!-- 4. Start Graph Planner for generating the global path on the map (DISABLED FOR AGENTIC NAVIGATION) -->
    <!-- <include file="$(find graph_planner)/launch/graph_planner.launch" /> -->

    <!-- 5. Start the existing Python Motion Primitives Planner -->
    <include file="$(find control_space_planner)/launch/run.launch" />

    <group if="$(arg use_rviz)">
        <node pkg="rviz" type="rviz" name="rviz_display" args="-d $(find hw4_exploration)/rviz/ee478_rtabmap.rviz" output="screen" />
    </group>
</launch>
